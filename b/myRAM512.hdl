// File name: projects/3/b/RAM512.hdl
/**
 * Memory of 512 16-bit registers.
 * If load is asserted, the value of the register selected by
 * address is set to in; Otherwise, the value does not change.
 * The value of the selected register is emitted by out.
 */
CHIP myRAM512 {
    IN in[16], load, address[9];
    OUT out[16];

    PARTS:
    //// Replace this comment with your code.
     myDMux8Way(in=load,sel=address[6..8],a=load1,b=load2,c=load3,d=load4,e=load5,f=load6,g=load7,h=load8);
    myRAM64(in=in,address=address[0..5],load=load1,out=out1);
    myRAM64(in=in,address=address[0..5],load=load2,out=out2);
    myRAM64(in=in,address=address[0..5],load=load3,out=out3);
    myRAM64(in=in,address=address[0..5],load=load4,out=out4);
    myRAM64(in=in,address=address[0..5],load=load5,out=out5);
    myRAM64(in=in,address=address[0..5],load=load6,out=out6);
    myRAM64(in=in,address=address[0..5],load=load7,out=out7);
    myRAM64(in=in,address=address[0..5],load=load8,out=out8);
    myMux8Way16(a=out1,b=out2,c=out3,d=out4,e=out5,f=out6,g=out7,h=out8,sel=address[6..8],out=out);

}
